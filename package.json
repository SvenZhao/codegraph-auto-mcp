{
  "name": "codegraph-auto-mcp",
  "displayName": "CodeGraph Auto MCP",
  "description": "Automatically registers CodeGraph MCP server when opening a project with .codegraph",
  "version": "0.0.6",
  "icon": "images/logo.png",
  "publisher": "svenzhao",
  "license": "MIT",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SvenZhao/codegraph-auto-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SvenZhao/codegraph-auto-mcp/issues"
  },
  "homepage": "https://github.com/SvenZhao/codegraph-auto-mcp#readme",
  "activationEvents": [
    "workspaceContains:.codegraph"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "codegraph",
        "label": "CodeGraph"
      }
    ]
  },
  "scripts": {
    "compile": "npm run check && npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "vscode:prepublish": "npm run build",
    "release": "standard-version",
    "publish": "npm run release && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.106.0",
    "esbuild": "^0.25.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.7.0"
  }
}
