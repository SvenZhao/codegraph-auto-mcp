{
  "name": "codegraph-auto-mcp",
  "displayName": "CodeGraph Auto MCP",
  "description": "Auto-registers CodeGraph MCP server for GitHub Copilot, with project init & re-index support",
  "version": "0.0.11",
  "icon": "images/logo.png",
  "publisher": "svenzhao",
  "license": "MIT",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SvenZhao/codegraph-auto-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/SvenZhao/codegraph-auto-mcp/issues"
  },
  "homepage": "https://github.com/SvenZhao/codegraph-auto-mcp#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codegraph.restart",
        "title": "CodeGraph: Restart MCP Server"
      },
      {
        "command": "codegraph.initProject",
        "title": "CodeGraph: Initialize Project"
      },
      {
        "command": "codegraph.sync",
        "title": "CodeGraph: Force Re-index"
      },
      {
        "command": "codegraph.showMenu",
        "title": "CodeGraph: Show Menu"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "codegraph",
        "label": "CodeGraph"
      }
    ],
    "configuration": {
      "title": "CodeGraph",
      "properties": {
        "codegraph.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "手动指定 codegraph CLI 的完整路径。留空则自动检测。\n\n如果已设置且可执行，将跳过自动查找流程。"
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run check && npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "vscode:prepublish": "npm run build",
    "release": "standard-version",
    "publish": "npm run release && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.106.0",
    "esbuild": "^0.25.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.7.0"
  }
}
